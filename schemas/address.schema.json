{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://metadata.openscan.io/schemas/address.schema.json",
	"title": "Address",
	"description": "Verified address metadata for apps and organizations.",
	"type": "object",
	"properties": {
		"address": {
			"type": "string",
			"description": "Checksummed Ethereum address",
			"pattern": "^0x[a-fA-F0-9]{40}$"
		},
		"chainId": {
			"type": "integer",
			"description": "Chain ID where this address is deployed"
		},
		"supporter": {
			"type": "string",
			"description": "ID of the app or organization this address belongs to"
		},
		"label": {
			"type": "string",
			"description": "Human-readable label for this address (e.g., 'Router V2', 'Treasury')"
		},
		"source": {
			"type": "array",
			"items": [
				{
					"type": "string",
					"description": "Data source name (e.g., openscan, kleros)"
				},
				{
					"type": "string",
					"format": "date",
					"description": "Date added or last updated (YYYY-MM-DD)"
				}
			],
			"minItems": 2,
			"additionalItems": false,
			"description": "Data source: [name, date added/updated]"
		}
	},
	"required": ["address", "chainId"],
	"additionalProperties": false
}
